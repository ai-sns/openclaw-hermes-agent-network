<p style=" margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; background-color:#2b2b2b;"><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6; background-color:#2b2b2b;">self.conversation_pages.addWidget(dialog)</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;"><br />print(</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#6a8759;">&quot;goingaddconver2&quot;</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">)<br /></span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#808080;"># self.mainwindow.conversation_pages.setCurrentIndex(2) #setCurrentWidget<br /></span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">self.note_editor_dialog = dialog<br />note_editor = dialog.findChild(QMainWindow</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">, </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#6a8759;">&quot;NoteEditorObject&quot;</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">)<br />note_editor.record_id = id<br />note_editor.loadFile()<br /></span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#808080;"># taskPage.new_task()<br /># taskPage.messageEdit.setFocus()<br /></span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">self.conversation_pages.setCurrentWidget(dialog)<br /><br />update by cjrokaa</span></p>
<p style=" margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; background-color:#2b2b2b;"><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">hellocjrbbb</span></p></body></html>