<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.0//EN" "http://www.w3.org/TR/REC-html40/strict.dtd">
<html><head><meta name="qrichtext" content="1" /><style type="text/css">
p, li { white-space: pre-wrap; }
</style></head><body style=" font-family:'Microsoft YaHei'; font-size:9.216pt; font-weight:400; font-style:normal;">
<p style=" margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;"><span style=" font-size:12pt;">动态加载插件</span></p>
<p style=" margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;"><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#808080;"># main.py<br /></span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">import </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">sys<br /></span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">import </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">importlib<br /></span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">from </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">PyQt5.QtWidgets </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">import </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">QApplication</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">, </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">QWidget</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">, </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">QVBoxLayout</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">, </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">QPushButton</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">, </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">QTabWidget<br /><br /><br /></span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">class </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">MainApp(QWidget):<br />    </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">def </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#b200b2;">__init__</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">(</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#94558d;">self</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">):<br />        </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#8888c6;">super</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">().</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#b200b2;">__init__</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">()<br />        </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#94558d;">self</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">.plugin_module = </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">None  </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#808080;"># </span><span style=" font-family:'宋体','monospace'; font-size:9.8pt; color:#808080;">初始化插件模块为</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#808080;"> None<br />        </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#94558d;">self</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">.initUI()<br /><br />    </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">def </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#ffc66d;">initUI</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">(</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#94558d;">self</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">):<br />        layout = QVBoxLayout()<br /><br />        </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#808080;"># </span><span style=" font-family:'宋体','monospace'; font-size:9.8pt; color:#808080;">创建标签页控件<br />        </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#94558d;">self</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">.tabs = QTabWidget()<br />        layout.addWidget(</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#94558d;">self</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">.tabs)<br /><br />        </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#808080;"># </span><span style=" font-family:'宋体','monospace'; font-size:9.8pt; color:#808080;">创建加载插件的按钮<br />        </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#94558d;">self</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">.button = QPushButton(</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#6a8759;">&quot;Load Plugin&quot;</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">)<br />        </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#94558d;">self</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">.button.clicked.connect(</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#94558d;">self</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">.load_plugin)<br />        layout.addWidget(</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#94558d;">self</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">.button)<br /><br />        </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#94558d;">self</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">.setLayout(layout)<br />        </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#94558d;">self</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">.setWindowTitle(</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#6a8759;">&quot;Plugin Loader with Tabs&quot;</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">)<br />        </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#94558d;">self</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">.setGeometry(</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#6897bb;">100</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">, </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#6897bb;">100</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">, </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#6897bb;">400</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">, </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#6897bb;">300</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">)<br /><br />    </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">def </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#ffc66d;">load_plugin</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">(</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#94558d;">self</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">):<br />        </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#808080;"># plugin_name = &quot;my_plugin&quot;  # </span><span style=" font-family:'宋体','monospace'; font-size:9.8pt; color:#808080;">插件模块名<br />        </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">plugin_name = </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#6a8759;">&quot;code_editor&quot;  </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#808080;"># </span><span style=" font-family:'宋体','monospace'; font-size:9.8pt; color:#808080;">插件模块名<br />        </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">try</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">:<br />            </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#808080;"># </span><span style=" font-family:'宋体','monospace'; font-size:9.8pt; color:#808080;">动态加载插件<br />            </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">if </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#94558d;">self</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">.plugin_module:<br />                importlib.reload(</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#94558d;">self</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">.plugin_module)  </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#808080;"># </span><span style=" font-family:'宋体','monospace'; font-size:9.8pt; color:#808080;">重新加载模块<br />            </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">else</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">:<br />                </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#94558d;">self</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">.plugin_module = importlib.import_module(</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#6a8759;">f'plugins.</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">{</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">plugin_name</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">}</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#6a8759;">'</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">)<br /><br />            </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#808080;"># </span><span style=" font-family:'宋体','monospace'; font-size:9.8pt; color:#808080;">获取插件类<br />            </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">plugin_class = </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#8888c6;">getattr</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">(</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#94558d;">self</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">.plugin_module</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">, </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#6a8759;">'CodeEditor'</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">)<br />            plugin_instance = plugin_class()  </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#808080;"># </span><span style=" font-family:'宋体','monospace'; font-size:9.8pt; color:#808080;">创建插件实例<br /><br />            </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#808080;"># </span><span style=" font-family:'宋体','monospace'; font-size:9.8pt; color:#808080;">创建插件的控件<br />            </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">plugin_widget = plugin_instance.create_widget()<br /><br />            </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#808080;"># </span><span style=" font-family:'宋体','monospace'; font-size:9.8pt; color:#808080;">添加新的标签页<br />            </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#808080;"># tab_index = self.tabs.addTab(plugin_widget, f&quot;Plugin {self.tabs.count() + 1}&quot;)<br />            </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">tab_index = </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#94558d;">self</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">.tabs.addTab(plugin_widget</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">, </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#6a8759;">f&quot;Plugin </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">{</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#94558d;">self</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">.tabs.count() + </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#6897bb;">1</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">}</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#6a8759;">&quot;</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">)<br />            </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#808080;">#tab_index = self.tabs.insertTab(0,plugin_widget, f&quot;Plugin {self.tabs.count() + 1}&quot;)<br /><br />            # </span><span style=" font-family:'宋体','monospace'; font-size:9.8pt; color:#808080;">自动切换到新添加的标签页<br />            </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#94558d;">self</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">.tabs.setCurrentIndex(tab_index)<br />        </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">except </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#8888c6;">Exception </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">as </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">e:<br />            </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#8888c6;">print</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">(</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#6a8759;">f&quot;Error loading plugin: </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">{</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">e</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">}</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#6a8759;">&quot;</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">)<br /><br /><br /></span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#cc7832;">if </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">__name__ == </span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#6a8759;">&quot;__main__&quot;</span><span style=" font-family:'JetBrains Mono','monospace'; font-size:9.8pt; color:#a9b7c6;">:<br />    app = QApplication(sys.argv)<br />    ex = MainApp()<br />    ex.show()<br />    sys.exit(app.exec_())<br /></span></p></body></html>